# Copy to .env and adjust. These override config.yaml values.
AI_PROVIDER=mock
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini
JWT_SECRET=ruyi-ai-admin-secret-change-me
PORT=8080
# SQLite file path (Linux/relative). When running under WSL against D:, use:
# DB_DSN=/mnt/d/ai-admin/server/data/app.db
DB_DSN=data/app.db
